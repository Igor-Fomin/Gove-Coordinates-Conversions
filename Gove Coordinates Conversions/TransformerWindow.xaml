<Window x:Class="GoveCivil3DPlugin.TransformerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gove Transformation Suite" Height="310" Width="500"
        Background="#2D2D2D" Foreground="#FFFFFF"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        FontFamily="Segoe UI" FontSize="12">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C97EA"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#555555"/>
                    <Setter Property="Foreground" Value="#AAAAAA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="GOVE TRANSFORMATION" FontSize="16" FontWeight="Bold" Foreground="#1C97EA"/>
            <TextBlock Text="Model Space Batch Transformation Suite" FontSize="10" Foreground="#AAAAAA"/>
        </StackPanel>

        <StackPanel x:Name="ControlsStack" Grid.Row="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <GroupBox Grid.Column="0" Header="Horizontal Transformations">
                    <StackPanel>
                        <Button Content="AMG84 ➔ MGA94" Click="ConvertAmgToMga_Click"/>
                        <Button Content="MGA94 ➔ AMG84" Click="ConvertMgaToAmg_Click" Margin="0"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Column="2" Header="Vertical Shifts">
                    <StackPanel>
                        <Button Content="AHD09 ➔ MBHD (+2.154m)" Click="ConvertAhdToMbhd_Click"/>
                        <Button Content="MBHD ➔ AHD09 (-2.154m)" Click="ConvertMbhdToAhd_Click" Margin="0"/>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </StackPanel>

        <TextBlock Grid.Row="2" x:Name="StatusLabel" Text="Status: Operational" Foreground="#E1E1E1" Margin="0,10,0,10" FontSize="12" FontWeight="SemiBold"/>
    </Grid>
</Window>
