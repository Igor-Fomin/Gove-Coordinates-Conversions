<Window x:Class="GoveCivil3DPlugin.TransformerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gove Geodetic Transformer" Height="380" Width="480"
        Background="#2D2D2D" Foreground="#FFFFFF"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        FontFamily="Segoe UI" FontSize="12">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C97EA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="GOVE GEODETIC ENGINE" FontSize="16" FontWeight="Bold" Foreground="#1C97EA"/>
            <TextBlock Text="High-Precision Spatial Coordinate Transformation" FontSize="10" Foreground="#AAAAAA"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#333333" CornerRadius="4" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Transformation Direction:" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#E1E1E1"/>
                <ComboBox x:Name="DirectionComboBox" SelectedIndex="0">
                    <ComboBoxItem Content="Gove AMG Zone 53 ➔ Gove MGA Zone 53 (Forward)"/>
                    <ComboBoxItem Content="Gove MGA Zone 53 ➔ Gove AMG Zone 53 (Inverse)"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <Button Grid.Row="2" x:Name="TransformButton" Click="TransformButton_Click" 
                Content="Select Objects &amp; Transform" FontWeight="Bold" FontSize="13" Height="40" Margin="0,0,0,15"/>

        <GroupBox Grid.Row="3" Header="Execution Log" Foreground="#AAAAAA" BorderBrush="#555555">
            <TextBox x:Name="LogConsole" Background="#1E1E1E" Foreground="#00FF00" 
                     FontFamily="Consolas" FontSize="11" IsReadOnly="True" 
                     VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Margin="5"
                     Text="[READY] Awaiting object selection context...&#x0a;"/>
        </GroupBox>

        <TextBlock Grid.Row="4" x:Name="StatusLabel" Text="Status: Idle" Foreground="#888888" Margin="0,10,0,0" FontSize="11"/>
    </Grid>
</Window>
